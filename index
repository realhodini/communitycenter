  .fp-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
  .fp-item { text-align: center; }
  .fp-item img { width: 100%; border: 1px solid var(--border); cursor: pointer; transition: transform .2s; background: #fff; }
  .fp-item img:hover { transform: scale(1.02); }
  .fp-item .fp-label { font-size: 0.72rem; margin-top: 6px; color: #777; letter-spacing: 1px; text-transform: uppercase; }

